# =============================================
# RAG Chatbot — Environment Configuration
# =============================================
# Copy this file to .env and fill in your values

# ------ REQUIRED ------
# Get your FREE Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# ------ OPTIONAL ------
# LLM Model (free options on Groq):
#   llama-3.1-8b-instant   → Fastest, great for most tasks (DEFAULT)
#   llama-3.1-70b-versatile → More powerful but slower
#   mixtral-8x7b-32768     → Great for long documents
#   gemma2-9b-it           → Google's model, very good
GROQ_MODEL=llama-3.1-8b-instant
